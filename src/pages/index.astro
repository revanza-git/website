---
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";

const metrics = [
  {
    value: "8+",
    label: "years shipping backend and data systems",
  },
  {
    value: "30+",
    label: "internal app databases consolidated",
  },
  {
    value: "5TB+",
    label: "national-scale data processed",
  },
  {
    value: "80h/mo",
    label: "manual operations effort removed",
  },
];

const focusAreas = [
  {
    title: "Enterprise AI systems",
    description:
      "RAG assistants, embeddings, vector retrieval, prompt orchestration, backend inference services, and enterprise UI integration.",
    accent: "text-blue-500",
    icon:
      "M4.5 6.75A2.25 2.25 0 016.75 4.5h10.5a2.25 2.25 0 012.25 2.25v10.5a2.25 2.25 0 01-2.25 2.25H6.75a2.25 2.25 0 01-2.25-2.25V6.75zm3 1.5h9m-9 3.75h9m-9 3.75h5.25",
  },
  {
    title: "Backend platforms",
    description:
      "Enterprise APIs, workflow engines, role-based access, audit trails, SQL-backed services, and production deployment.",
    accent: "text-cyan-500",
    icon:
      "M8.25 7.5h-1.5A2.25 2.25 0 004.5 9.75v4.5a2.25 2.25 0 002.25 2.25h1.5m7.5-9h1.5a2.25 2.25 0 012.25 2.25v4.5a2.25 2.25 0 01-2.25 2.25h-1.5M8.25 12h7.5",
  },
  {
    title: "Data and reporting layers",
    description:
      "Airflow, NiFi, SQL Server, BigQuery, Power BI/Fabric, snapshot pipelines, and executive decision-support datasets.",
    accent: "text-emerald-500",
    icon:
      "M6 18.75V12m6 6.75V5.25m6 13.5v-9M4.5 12h3m3-6.75h3m3 4.5h3M7.5 12a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm6-6.75a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm6 4.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z",
  },
  {
    title: "Technical delivery leadership",
    description:
      "Squad leadership, code review, mentoring, vendor coordination, and SDLC ownership from design to deployment.",
    accent: "text-amber-500",
    icon:
      "M5.25 18.75l4.5-4.5m0 0l3 3L18.75 9m-9 5.25l-3-3L3.75 14.25m15-9h-5.25m5.25 0v5.25",
  },
];

const proofPoints = [
  "Architected an on-premise LLM knowledge assistant and redesigned it into a RAG pipeline with chunking, embeddings, vector retrieval, contextual prompts, and controlled output handling.",
  "Built Apache Airflow pipelines that turn multi-source LNG operations data into governed snapshot tables and board-level reporting datasets.",
  "Led 7 cross-functional Agile squads across architecture, code review, vendor coordination, deployment, and operational governance.",
];
---

<Layout title="Revanza Raytama | Senior Backend & AI Systems Engineer">
  <section
    class="relative z-20 w-full max-w-5xl px-6 mx-auto mt-10 md:mt-16 lg:mt-20"
  >
    <div
      class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14"
    >
      <div class="relative">
        <p
          class="mb-4 text-xs font-semibold tracking-[0.28em] uppercase text-blue-600 dark:text-blue-400"
        >
          Senior Backend Engineer / AI Systems Engineer
        </p>
        <h1
          class="max-w-3xl text-[2.35rem] font-bold leading-[1.03] text-neutral-950 [text-wrap:balance] sm:text-5xl md:text-[3.35rem] dark:text-white"
        >
          I build enterprise backend, data, and AI systems that survive real operations<span
            class="text-blue-500">.</span
          >
        </h1>

        <p
          class="max-w-2xl mt-6 text-base leading-8 text-neutral-600 dark:text-neutral-400 md:text-lg"
        >
          Hi, I'm Revanza Raytama. I design backend architectures, data
          pipelines, and LLM/RAG-enabled internal platforms for energy,
          insurance, and telecom operations, with enough delivery leadership to
          take systems from design to production.
        </p>

        <div class="grid max-w-2xl grid-cols-2 gap-3 mt-7 sm:grid-cols-4">
          {
            metrics.map((metric) => (
              <div class="border rounded-[8px] border-neutral-200 bg-white/80 p-3 shadow-sm dark:border-neutral-800 dark:bg-neutral-950/70">
                <p class="text-xl font-bold text-neutral-950 sm:text-2xl dark:text-white">
                  {metric.value}
                </p>
                <p class="mt-1 text-xs leading-5 text-neutral-500 dark:text-neutral-400">
                  {metric.label}
                </p>
              </div>
            ))
          }
        </div>

        <div class="flex flex-col gap-3 mt-8 sm:flex-row">
          <a
            href="/assets/documents/Revanza_Raytama_Resume_final.docx"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white duration-200 bg-neutral-950 rounded-full shadow-sm hover:-translate-y-0.5 hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
          >
            Download resume
            <svg
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M12 3v12"></path>
              <path d="m7 10 5 5 5-5"></path>
              <path d="M5 21h14"></path>
            </svg>
          </a>
          <a
            href="https://github.com/revanza-git"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold duration-200 border rounded-full border-neutral-200 bg-white/80 text-neutral-800 shadow-sm hover:-translate-y-0.5 hover:border-blue-500 hover:text-blue-600 dark:border-neutral-800 dark:bg-neutral-950/80 dark:text-neutral-200 dark:hover:border-blue-500 dark:hover:text-blue-400"
          >
            <svg
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5a10.3 10.3 0 0 0-5.5 0C8 2 7 2 7 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 6 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
            View GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/revanzaraytama/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold duration-200 border rounded-full border-neutral-200 bg-white/80 text-neutral-800 shadow-sm hover:-translate-y-0.5 hover:border-blue-500 hover:text-blue-600 dark:border-neutral-800 dark:bg-neutral-950/80 dark:text-neutral-200 dark:hover:border-blue-500 dark:hover:text-blue-400"
          >
            LinkedIn
          </a>
        </div>
      </div>

      <div class="relative">
        <div
          class="relative mx-auto max-w-sm overflow-hidden border rounded-[8px] border-neutral-200 bg-neutral-100 shadow-2xl shadow-neutral-200/70 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-black/30 lg:max-w-md"
        >
          <div
            class="absolute inset-0 bg-[linear-gradient(135deg,rgba(59,130,246,0.12),transparent_34%,rgba(16,185,129,0.14)_72%,transparent)]"
          >
          </div>
          <img
            src="/assets/images/main-hero.jpeg"
            alt="Illustrated portrait of Revanza holding a laptop"
            loading="eager"
            decoding="async"
            class="relative z-10 w-full aspect-[4/5] object-cover object-center"
          />
        </div>

        <div
          class="grid grid-cols-1 gap-3 mt-4 text-sm sm:grid-cols-2"
          aria-label="Core capabilities"
        >
          {
            focusAreas.map((item) => (
              <article class="border rounded-[8px] border-neutral-200 bg-white/80 p-4 shadow-sm backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/75">
                <svg
                  class={`mb-3 h-5 w-5 ${item.accent}`}
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.8"
                  aria-hidden="true"
                >
                  <path d={item.icon}></path>
                </svg>
                <h2 class="font-semibold leading-5 text-neutral-900 dark:text-white">
                  {item.title}
                </h2>
                <p class="mt-1 text-xs leading-5 text-neutral-500 dark:text-neutral-400">
                  {item.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-20 w-full max-w-5xl px-6 mx-auto mt-16">
    <div
      class="grid gap-6 border rounded-[8px] border-neutral-200 bg-white/80 p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-950/75 md:grid-cols-[0.8fr_1.2fr]"
    >
      <div>
        <p
          class="text-xs font-semibold tracking-[0.24em] uppercase text-blue-600 dark:text-blue-400"
        >
          AI and platform proof
        </p>
        <h2
          class="mt-3 text-2xl font-bold tracking-tight text-neutral-950 dark:text-white"
        >
          Production-minded AI, not demo-only chatbots.
        </h2>
      </div>
      <ul class="space-y-4">
        {
          proofPoints.map((point) => (
            <li class="flex gap-3 text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-blue-500" />
              <span>{point}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <Separator text="Selected systems" />
  <Projects />
  <Separator text="Some of my writing" />
  <Writings />
</Layout>
