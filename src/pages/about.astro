---
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import PageHeading from "../components/page-heading.astro";
import ScheduleMeeting from "../components/schedule-meeting.astro";
import Layout from "../layouts/main.astro";

const strengths = [
  "Backend architecture for internal platforms, APIs, approval workflows, and operational systems.",
  "LLM/RAG integration with embeddings, vector retrieval, prompt orchestration, and backend inference services.",
  "Data integration and reporting layers across SQL Server, BigQuery, Airflow, NiFi, Power BI, and Microsoft Fabric.",
  "Technical leadership across code review, mentoring, vendor coordination, Agile delivery, and production governance.",
];

const contactLinks = [
  {
    label: "Download Resume",
    href: "/assets/documents/Revanza_Raytama_Resume_final.docx",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/revanzaraytama/",
    external: true,
  },
  {
    label: "GitHub",
    href: "https://github.com/revanza-git",
    external: true,
  },
  {
    label: "Email",
    href: "mailto:revanza.raytama@gmail.com",
  },
];
---

<Layout title="About Revanza Raytama | Backend & AI Systems Engineer">
  <section class="relative z-20 max-w-3xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="About Revanza"
      description="Senior Backend Engineer from Jakarta with 8+ years building enterprise backend systems, data integration layers, internal productivity platforms, and AI/LLM-enabled applications. I work best where software has to connect messy operations, legacy systems, reporting needs, and real production constraints."
    />

    <img
      src="/assets/images/about2.jpeg"
      alt="Revanza profile photo"
      class="relative z-30 w-full my-10 rounded-[8px]"
    />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Profile</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      My recent work sits across <strong>backend architecture</strong>,
      <strong>AI/RAG systems</strong>, and <strong>data platforms</strong> for
      energy, insurance, and telecom environments. I have built governed
      reporting stores from 30+ internal databases, industrial data pipelines
      that removed manual Excel workflows, and LLM-powered knowledge assistants
      designed for enterprise use rather than demo-only interaction.
    </p>

    <div
      class="grid gap-3 mt-8 sm:grid-cols-2"
      aria-label="Core strengths"
    >
      {
        strengths.map((strength) => (
          <div class="rounded-[8px] border border-neutral-200 bg-white/80 p-4 text-sm leading-6 text-neutral-600 shadow-sm dark:border-neutral-800 dark:bg-neutral-950/75 dark:text-neutral-400">
            {strength}
          </div>
        ))
      }
    </div>

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
    <div class="py-8 sm:py-10 sm:pl-8">
      {
        experiences.map((experience, index) => {
          const isLast = index === experiences.length - 1;
          return (
            <div
              class={`relative ${
                !isLast
                  ? "sm:border-l sm:border-gray-200 sm:dark:border-neutral-700"
                  : ""
              } pb-5 sm:pb-12`}
            >
              <AboutExperience
                dates={experience.dates}
                role={experience.role}
                company={experience.company}
                description={experience.description}
                logo={experience.logo}
              />
            </div>
          );
        })
      }
    </div>

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Let's Connect
    </h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      For hiring, collaboration, or technical conversations, these are the
      fastest ways to review my background and reach me.
    </p>

    <div class="flex flex-wrap gap-3 mt-5">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="inline-flex items-center justify-center rounded-full border border-neutral-200 bg-white px-4 py-2 text-sm font-semibold text-neutral-800 shadow-sm duration-200 hover:-translate-y-0.5 hover:border-blue-500 hover:text-blue-600 dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-200 dark:hover:border-blue-500 dark:hover:text-blue-400"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="mt-3">
      <ScheduleMeeting />
    </div>
  </section>
</Layout>
