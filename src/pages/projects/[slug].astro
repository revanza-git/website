---
import projects from "../../collections/projects.json";
import Layout from "../../layouts/main.astro";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const additionalScreenshots = project.screenshots?.slice(1) ?? [];

const caseSections = [
  {
    title: "Problem",
    body: project.problem,
  },
  {
    title: "Solution",
    body: project.solution,
  },
  {
    title: "Proof",
    points: project.proof,
  },
  {
    title: "Result",
    body: project.result,
  },
];
---

<Layout title={`${project.name} | Project Case Study`}>
  <main class="relative z-20 w-full max-w-4xl px-6 mx-auto my-12 lg:px-0">
    <a
      href="/projects"
      class="inline-flex items-center gap-2 text-sm font-semibold text-neutral-500 duration-200 hover:text-blue-600 dark:text-neutral-400 dark:hover:text-blue-400"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Projects
    </a>

    <section class="mt-8">
      <p
        class="text-xs font-semibold tracking-[0.28em] uppercase text-blue-600 dark:text-blue-400"
      >
        Project Case Study
      </p>
      <h1
        class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-neutral-950 dark:text-white md:text-5xl"
      >
        {project.name}
      </h1>
      <p
        class="mt-5 max-w-3xl text-base leading-8 text-neutral-600 dark:text-neutral-400 md:text-lg"
      >
        {project.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {
          project.stacks.map((stack) => (
            <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-600 dark:bg-neutral-900 dark:text-neutral-400">
              {stack}
            </span>
          ))
        }
      </div>

      {
        project.links.length > 0 && (
          <div class="mt-7 flex flex-wrap gap-3">
            {project.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-neutral-200 bg-white px-4 py-2 text-sm font-semibold text-neutral-800 shadow-sm duration-200 hover:-translate-y-0.5 hover:border-blue-500 hover:text-blue-600 dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-200 dark:hover:border-blue-500 dark:hover:text-blue-400"
              >
                {link.label}
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M7 17 17 7"></path>
                  <path d="M7 7h10v10"></path>
                </svg>
              </a>
            ))}
          </div>
        )
      }
    </section>

    <img
      src={project.image}
      alt={project.name}
      class="mt-10 w-full rounded-[8px] border border-neutral-200 bg-neutral-100 object-cover shadow-sm dark:border-neutral-800 dark:bg-neutral-900"
    />

    {
      additionalScreenshots.length > 0 && (
        <section
          class={`mt-6 grid gap-4 ${additionalScreenshots.length > 1 ? "md:grid-cols-2" : ""}`}
          aria-label="Additional project screenshots"
        >
          {additionalScreenshots.map((screenshot) => (
            <figure class="overflow-hidden rounded-[8px] border border-neutral-200 bg-white shadow-sm dark:border-neutral-800 dark:bg-neutral-950">
              <img
                src={screenshot.src}
                alt={screenshot.alt}
                class="h-full w-full object-cover"
              />
            </figure>
          ))}
        </section>
      )
    }

    <section class="mt-12" aria-label="Project case study">
      {
        caseSections.map((section) => (
          <article class="border-t border-neutral-200 py-8 dark:border-neutral-800">
            <h2 class="text-2xl font-bold tracking-tight text-neutral-950 dark:text-white">
              {section.title}
            </h2>
            {section.points ? (
              <ul class="mt-5 space-y-4">
                {section.points.map((point) => (
                  <li class="flex gap-3 text-sm leading-7 text-neutral-600 dark:text-neutral-400">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-blue-500" />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-4 text-sm leading-7 text-neutral-600 dark:text-neutral-400 md:text-base md:leading-8">
                {section.body}
              </p>
            )}
          </article>
        ))
      }
    </section>
  </main>
</Layout>
