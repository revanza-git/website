---
const { name, description, url, image, stacks = [] } = Astro.props;
const isExternal = typeof url === "string" && /^https?:\/\//.test(url);
---

<a
  href={url}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class="group flex h-full flex-col overflow-hidden rounded-[8px] border border-neutral-200 bg-white shadow-sm duration-200 hover:-translate-y-1 hover:border-blue-400 hover:shadow-lg dark:border-neutral-800 dark:bg-neutral-950"
>
  <span class="block w-full overflow-hidden bg-neutral-100 dark:bg-neutral-900">
    <img
      src={image}
      alt={name}
      class="w-full h-auto aspect-[16/9] object-cover duration-300 group-hover:scale-[1.03]"
    />
  </span>
  <span class="flex grow flex-col p-4">
    <span
      class="flex items-start justify-between gap-3 text-base font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
    >
      <span>{name}</span>
      <svg
        class="mt-1 h-4 w-4 shrink-0 text-neutral-400 duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-blue-500"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M7 17 17 7"></path>
        <path d="M7 7h10v10"></path>
      </svg>
    </span>
    <span class="mt-2 block text-sm leading-6 text-neutral-600 dark:text-neutral-400"
      >{description}</span
    >
    <span class="mt-4 flex flex-wrap gap-2">
      {
        Array.isArray(stacks) &&
          stacks.map((stack) => (
            <span class="rounded-full bg-neutral-100 px-2 py-1 text-[0.68rem] font-semibold text-neutral-600 dark:bg-neutral-900 dark:text-neutral-400">
              {stack}
            </span>
          ))
      }
    </span>
  </span>
</a>
